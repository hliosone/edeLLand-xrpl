# XRPL Connect Configuration
# Copy this file to .env.local and fill in your API keys

# Xaman (formerly Xumm) API Key
# Get your API key from https://apps.xumm.dev/
NEXT_PUBLIC_XAMAN_API_KEY=your_xaman_api_key_here
# WalletConnect Project ID
# Get your project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── Collateral Escrow Wallet (generated by setup script) ──────────────────────
# Holds XRP collateral for collateralised loans. Platform-controlled.
# Platform is added as weight-2 co-signer on user wallets (quorum 2) for enforcement.
COLLATERAL_ESCROW_WALLET_ADDRESS=
COLLATERAL_ESCROW_WALLET_SEED=

# ── Collateral risk thresholds ────────────────────────────────────────────────
# health = (locked_XRP * xrp_usd) / outstanding_RLUSD * 100
# Initial required ratio at deposit: 125%
# Warning  → show orange alert on loan card
COLLATERAL_WARNING_THRESHOLD=120
# Liquidation → auto-liquidate position
COLLATERAL_LIQUIDATION_THRESHOLD=112
